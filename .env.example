# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database (PostgreSQL via Neon — https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/xxyx_db?sslmode=require"

# JWT
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173
