# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database (PostgreSQL via Neon — https://neon.tech)
# Pakai endpoint *-pooler* untuk app runtime (bukan direct) agar connection pool > 1.
# Contoh: ep-xxxx-pooler.ap-southeast-1.aws.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/xxyx_db?sslmode=require&pgbouncer=true&connection_limit=5&pool_timeout=20"
# Direct URL untuk prisma migrate (non-pooler)
DIRECT_URL="postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/xxyx_db?sslmode=require"

# JWT
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS (pisahkan dengan koma kalau butuh lebih dari 1 origin, mis. dev + production)
CORS_ORIGIN=http://localhost:5173,https://swayen.vercel.app
